# ─── Printful ────────────────────────────────────────────────────────────────
# https://www.printful.com/dashboard/store → Developers → API Key
PRINTFUL_API_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Webhook secret — register the endpoint in Stripe first:
# Dashboard → Developers → Webhooks → Add endpoint
# URL: https://YOUR_DOMAIN/api/webhook/stripe   Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=

# ─── Solana ──────────────────────────────────────────────────────────────────
MERCHANT_SOLANA_WALLET=        # Your wallet address (receives SOL payments)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─── Helius ──────────────────────────────────────────────────────────────────
# https://dev.helius.xyz/ — NFT discovery & on-chain data
HELIUS_KEY=

# ─── Tensor ──────────────────────────────────────────────────────────────────
# https://api.tensor.so (Dashboard → API Keys)
# Used to verify Cubs holdings + fetch traits for Moltbook
TENSOR_API_KEY=

# ─── Collection ──────────────────────────────────────────────────────────────
# On-chain collection address for OkayCubs (enables getAssetsByGroup)
# Leave empty to fall back to name-based search
OKAYCUBS_COLLECTION_ADDRESS=
